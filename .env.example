# Cloudflare Turnstile — public site key (safe to expose, NOT the secret key)
# Get it from: https://dash.cloudflare.com → Turnstile
NUXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Worker URL — the deployed contact form worker endpoint
# Example: https://portfolio-contact.your-subdomain.workers.dev/
NUXT_PUBLIC_WORKER_URL=
